# =============================================================================
# PRODUCTION ENVIRONMENT — copy to .env, fill ALL values, chmod 600 .env
# =============================================================================

# --- Deployment (used by docker-compose.yml for image tag and GHCR pull) ---
APP_VERSION=v1.0.0
GHCR_ORG=akim4ik

# --- Database password ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(24))"
DB_PASSWORD=

# --- App runtime ---
DEBUG=false
LOG_LEVEL=INFO
TZ=Europe/Moscow

# --- CORS: exact origin the browser will use (no trailing slash) ---
# Example: https://jira-analytics.company.local
CORS_ORIGINS=

# --- Authentication ---
# Generate JWT_SECRET_KEY once, never rotate (invalidates all sessions):
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=8
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# --- Initial admin account (created on first startup via create_admin.py) ---
# REMOVE ADMIN_PASSWORD from this file after the first login and password change.
ADMIN_EMAIL=admin@company.ru
ADMIN_PASSWORD=

# --- LLM API keys (leave blank to disable AI summaries) ---
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Backups (см. docs/backup-restore.md) ---
# Расписание в cron-формате (5 полей) или alias: @daily / @hourly / @weekly
BACKUP_SCHEDULE=0 3 * * *
# Сколько копий хранить по каждой категории
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# =============================================================================
# DO NOT ADD:
#   DATABASE_URL  — constructed by docker-compose.yml from DB_PASSWORD above
#   HF_HOME       — set by docker-compose.yml to /opt/hf-cache (model is baked in image)
#   JIRA_*        — Jira credentials live in the database (app_settings table),
#                   set them via the /settings page in the UI after first login
# =============================================================================
